{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neural-brain.invalid/contracts/envelopes.schema.json",
  "title": "Neural Brain memory envelopes",
  "description": "Typed boundary for governed memory requests and records. Scope and actor fields are trusted server-derived context; consumer correlations are optional untrusted metadata.",
  "oneOf": [
    {
      "$ref": "#/$defs/MemoryRequestEnvelope"
    },
    {
      "$ref": "#/$defs/MemoryRecordEnvelope"
    }
  ],
  "$defs": {
    "OpaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "ScopeContext": {
      "type": "object",
      "description": "Immutable scope derived exclusively from authenticated runtime context. Goal is not a Neural Brain scope level.",
      "required": [
        "scope_level",
        "tenant_id",
        "area_id"
      ],
      "properties": {
        "scope_level": {
          "enum": [
            "area",
            "project",
            "session"
          ]
        },
        "tenant_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "area_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "project_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "session_id": {
          "$ref": "#/$defs/OpaqueId"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scope_level": {
                "const": "area"
              }
            },
            "required": [
              "scope_level"
            ]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "project_id"
                  ]
                },
                {
                  "required": [
                    "session_id"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "scope_level": {
                "const": "project"
              }
            },
            "required": [
              "scope_level"
            ]
          },
          "then": {
            "required": [
              "project_id"
            ],
            "not": {
              "required": [
                "session_id"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "scope_level": {
                "const": "session"
              }
            },
            "required": [
              "scope_level"
            ]
          },
          "then": {
            "required": [
              "project_id",
              "session_id"
            ]
          }
        }
      ],
      "additionalProperties": false,
      "x-trust-source": "authenticated_runtime_context",
      "x-immutable": true,
      "x-catalog-contract": "scope-catalog.json",
      "x-operational-memory-scope": true
    },
    "ActorContext": {
      "type": "object",
      "required": [
        "principal_id",
        "principal_kind",
        "runtime_component_id"
      ],
      "properties": {
        "principal_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "principal_kind": {
          "enum": [
            "human",
            "service"
          ]
        },
        "runtime_component_id": {
          "$ref": "#/$defs/OpaqueId"
        }
      },
      "additionalProperties": false,
      "x-trust-source": "authenticated_runtime_context",
      "x-immutable": true
    },
    "TraceContext": {
      "type": "object",
      "required": [
        "correlation_id",
        "causation_id"
      ],
      "properties": {
        "correlation_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "causation_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "x-trust-source": "trusted_ingress_or_memory_gate",
      "x-immutable": true
    },
    "GovernanceContext": {
      "type": "object",
      "required": [
        "classification_id",
        "purpose_id",
        "retention_policy_id",
        "deletion_responsibility_id"
      ],
      "properties": {
        "classification_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "purpose_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "retention_policy_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "deletion_responsibility_id": {
          "$ref": "#/$defs/OpaqueId"
        }
      },
      "additionalProperties": false
    },
    "ProvenanceContext": {
      "type": "object",
      "required": [
        "provenance_kind_id",
        "source_refs",
        "captured_at"
      ],
      "properties": {
        "provenance_kind_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OpaqueId"
          },
          "uniqueItems": true
        },
        "captured_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})$"
        }
      },
      "additionalProperties": false
    },
    "ConsumerCorrelation": {
      "type": "object",
      "description": "Optional untrusted opaque consumer metadata. These values confer no scope, identity, authority, lifecycle, or referential-integrity semantics inside Neural Brain.",
      "properties": {
        "consumer_session_ref": {
          "$ref": "#/$defs/OpaqueId"
        },
        "consumer_goal_ref": {
          "$ref": "#/$defs/OpaqueId"
        },
        "consumer_task_ref": {
          "$ref": "#/$defs/OpaqueId"
        }
      },
      "minProperties": 1,
      "additionalProperties": false,
      "x-trust-source": "untrusted_consumer_metadata",
      "x-authoritative": false
    },
    "MemoryEnvelopeHeader": {
      "type": "object",
      "required": [
        "contract_version",
        "envelope_id",
        "scope",
        "actor",
        "trace",
        "governance",
        "provenance",
        "recorded_at"
      ],
      "properties": {
        "contract_version": {
          "const": "2.0.0"
        },
        "envelope_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "scope": {
          "$ref": "#/$defs/ScopeContext"
        },
        "actor": {
          "$ref": "#/$defs/ActorContext"
        },
        "trace": {
          "$ref": "#/$defs/TraceContext"
        },
        "governance": {
          "$ref": "#/$defs/GovernanceContext"
        },
        "provenance": {
          "$ref": "#/$defs/ProvenanceContext"
        },
        "consumer_correlation": {
          "$ref": "#/$defs/ConsumerCorrelation"
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})$"
        }
      },
      "x-direct-persistence": "forbidden",
      "x-transition-gate": "Memory Transition Gate"
    },
    "MemoryRequestEnvelope": {
      "allOf": [
        {
          "$ref": "#/$defs/MemoryEnvelopeHeader"
        },
        {
          "type": "object",
          "required": [
            "envelope_kind",
            "operation_id",
            "payload_schema_id",
            "payload_digest"
          ],
          "properties": {
            "envelope_kind": {
              "const": "memory_request"
            },
            "operation_id": {
              "enum": [
                "memory.observe",
                "memory.checkpoint",
                "memory.propose_candidate",
                "memory.persist_episode_or_claim",
                "memory.retrieve",
                "memory.promote_candidate",
                "memory.quarantine_or_rollback",
                "memory.delete_or_anonymize"
              ]
            },
            "payload_schema_id": {
              "$ref": "#/$defs/OpaqueId"
            },
            "payload_digest": {
              "$ref": "#/$defs/OpaqueId"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "MemoryRecordEnvelope": {
      "allOf": [
        {
          "$ref": "#/$defs/MemoryEnvelopeHeader"
        },
        {
          "type": "object",
          "required": [
            "envelope_kind",
            "memory_record_id",
            "memory_kind",
            "lifecycle_state",
            "freshness",
            "content_schema_id",
            "content_digest"
          ],
          "properties": {
            "envelope_kind": {
              "const": "memory_record"
            },
            "memory_record_id": {
              "$ref": "#/$defs/OpaqueId"
            },
            "memory_kind": {
              "enum": [
                "working_context",
                "checkpoint",
                "observation",
                "candidate",
                "episode",
                "semantic_claim",
                "procedural_memory"
              ]
            },
            "lifecycle_state": {
              "enum": [
                "inactive",
                "under_assessment",
                "active",
                "superseded",
                "rejected",
                "quarantined",
                "deleted",
                "anonymized"
              ]
            },
            "freshness": {
              "enum": [
                "current",
                "stale",
                "expired",
                "unknown"
              ]
            },
            "content_schema_id": {
              "$ref": "#/$defs/OpaqueId"
            },
            "content_digest": {
              "$ref": "#/$defs/OpaqueId"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "x-deferred-decisions": [
    {
      "id": "identifier_encoding_and_generation",
      "status": "deferred_requires_accepted_adr"
    },
    {
      "id": "digest_algorithm_and_value_encoding",
      "status": "deferred_requires_accepted_security_adr"
    }
  ]
}
