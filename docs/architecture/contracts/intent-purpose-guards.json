{
  "document_type": "intent_purpose_guard_contract",
  "format_version": 1,
  "contract_id": "neural-brain.intent-purpose-guards",
  "contract_version": "1.0.0",
  "status": "normative",
  "work_item": "FND-02.4",
  "sources": [
    "docs/architecture/architecture-directive-v1.1.md",
    "docs/adr/ADR-005-hard-security-floor-and-bounded-policy.md",
    "docs/adr/ADR-007-normative-goal-and-action-state-machines.md",
    "docs/adr/ADR-008-atomic-action-preparation-and-commit.md"
  ],
  "canonical_purposes": ["execution", "verification", "cancellation", "reconciliation", "compensation"],
  "purpose_immutability": "purpose is fixed when the intent is proposed and cannot change during its lifetime",
  "purpose_profiles": {
    "execution": {
      "permitted_request_actors": ["planner"],
      "proposal_authority": ["action.propose.execution"],
      "commit_authority_snapshot": ["action.execute", "tool.operation.execute"],
      "required_policy": ["security_floor_allow", "operation_policy_allow", "risk_classified", "kill_switch_permissive"],
      "approval": {"mode": "conditional", "condition_rule_ids": ["PG-APPROVAL-RISK-CONTRACT"], "separation_rule_ids": ["PG-SOD-ELEVATED-RISK"]},
      "evidence": ["accepted_goal", "bounded_plan_step", "registered_operation_contract"],
      "external_effect": "permitted only after committed"
    },
    "verification": {
      "permitted_request_actors": ["independent_verifier"],
      "proposal_authority": ["action.propose.verification"],
      "commit_authority_snapshot": ["evidence.verify"],
      "required_policy": ["security_floor_allow", "verification_policy_allow", "kill_switch_permissive"],
      "approval": {"mode": "conditional", "condition_rule_ids": ["PG-APPROVAL-OPERATION-CONTRACT"], "separation_rule_ids": ["PG-SOD-ELEVATED-RISK"]},
      "evidence": ["machine_readable_success_criteria", "evidence_package", "verifier_independence_proof"],
      "external_effect": "read-only by default; a mutating verification operation requires the full external-effect contract"
    },
    "cancellation": {
      "permitted_request_actors": ["goal_requester", "authorized_operator", "guardian", "runtime_coordinator"],
      "proposal_authority": ["action.propose.cancellation"],
      "commit_authority_snapshot": ["action.cancel"],
      "required_policy": ["security_floor_allow", "cancellation_policy_allow"],
      "approval": {"mode": "prohibited_for_stop_request", "condition_rule_ids": ["PG-EMERGENCY-STOP-NO-DELAY"], "separate_effect_rule_ids": ["PG-COMPENSATION-SEPARATE-INTENT"]},
      "evidence": ["cancellation_reason", "target_intent", "current_effect_disposition"],
      "external_effect": "only the registered cancellation operation; uncertainty becomes indeterminate"
    },
    "reconciliation": {
      "permitted_request_actors": ["reconciliation_adapter", "guardian", "authorized_operator"],
      "proposal_authority": ["action.propose.reconciliation"],
      "commit_authority_snapshot": ["action.reconcile"],
      "required_policy": ["security_floor_allow", "reconciliation_policy_allow"],
      "approval": {"mode": "conditional", "condition_rule_ids": ["PG-APPROVAL-NEW-EXTERNAL-EFFECT"], "separation_rule_ids": ["PG-SOD-ELEVATED-RISK"]},
      "evidence": ["durable_attempt_state", "dispatch_journal_entry", "registered_reconciliation_strategy"],
      "external_effect": "read-only unless a separately authorized operation contract explicitly permits mutation"
    },
    "compensation": {
      "permitted_request_actors": ["authorized_operator", "runtime_coordinator"],
      "proposal_authority": ["action.propose.compensation"],
      "commit_authority_snapshot": ["action.compensate", "tool.operation.execute"],
      "required_policy": ["security_floor_allow", "compensation_policy_allow", "risk_classified", "kill_switch_permissive"],
      "approval": {"mode": "conditional", "condition_rule_ids": ["PG-APPROVAL-RISK-CONTRACT"], "separation_rule_ids": ["PG-SOD-ELEVATED-RISK"]},
      "evidence": ["effect_confirmed", "registered_compensation_contract", "compensation_preconditions"],
      "external_effect": "permitted only after a distinct compensation intent is committed"
    }
  },
  "goal_state_matrix": {
    "proposed": [],
    "active": ["execution"],
    "suspended": [],
    "blocked": ["cancellation", "reconciliation", "compensation"],
    "verifying": ["verification"],
    "terminating": ["cancellation", "reconciliation", "compensation"],
    "achieved": [],
    "failed": [],
    "discarded": []
  },
  "rule_registry": {
    "PG-SCOPE-MATCH": {"operator": "all_equal", "left": "intent.scope", "right": "goal.scope", "fields": ["tenant_id", "area_id", "project_id", "session_id", "goal_id"]},
    "PG-ACTOR-PURPOSE": {"operator": "resolved_binding_allows_actor_kind", "principal_ref": "actor_context.principal_id", "component_ref": "actor_context.runtime_component_id", "binding_source": "authoritative_role_binding_store", "scope_ref": "scope_context", "allowed_actor_kinds_ref": "purpose_profiles.{purpose}.permitted_request_actors"},
    "PG-PROPOSAL-AUTHORITY": {"operator": "contains_all", "value": "proposal_authority_snapshot.grants", "scope_ref": "scope_context", "set_ref": "purpose_profiles.{purpose}.proposal_authority"},
    "PG-COMMIT-AUTHORITY": {"operator": "contains_all", "value": "authority_snapshot.grants", "set_ref": "purpose_profiles.{purpose}.commit_authority_snapshot"},
    "PG-APPROVAL-NOT-AUTHORITY": {"operator": "must_not_satisfy", "value": "approval_claim", "requirement": "missing_authority_or_security_floor_denial"},
    "PG-COMMIT-REVALIDATE": {"operator": "all_current_and_matching", "inputs": ["policy_decision", "approval_claims", "authority_snapshot", "operation_registry_entry", "scope_context", "local_runtime_fence", "deadline", "kill_switch_state"]},
    "PG-TARGET-BOUND-WORK": {"operator": "requires_existing_target", "when": {"purpose_in": ["cancellation", "reconciliation"]}, "required_reference": "target_action_intent_id_or_effect_id", "scope_match_rule": "PG-SCOPE-MATCH"},
    "PG-COMPENSATION-TARGET": {"operator": "requires_confirmed_effect_reference", "when": {"purpose": "compensation"}, "required_reference": "original_effect_id", "requires_distinct_intent": true},
    "PG-NO-INTENT": {"operator": "deny_when", "goal_state_in": ["proposed", "suspended", "achieved", "failed", "discarded"]},
    "PG-COMPENSATION-SEPARATE-INTENT": {"operator": "requires_distinct_intent", "purpose": "compensation", "forbids": ["purpose_mutation", "reuse_original_execution_grant"]},
    "PG-INDETERMINATE-RESTRICT": {"operator": "allow_only", "when": {"action_state": "indeterminate"}, "transition_ids": ["action.resolve_effect_confirmed", "action.resolve_no_effect_confirmed", "action.resolve_effect_compensated"]},
    "PG-APPROVAL-RISK-CONTRACT": {"operator": "required_when", "condition": "operation_contract.approval_required_or_risk_requires_approval"},
    "PG-APPROVAL-OPERATION-CONTRACT": {"operator": "required_when", "condition": "operation_contract.approval_required"},
    "PG-APPROVAL-NEW-EXTERNAL-EFFECT": {"operator": "required_when", "condition": "operation_contract.external_effect_new"},
    "PG-SOD-ELEVATED-RISK": {"operator": "not_equal", "when": {"risk_class": "elevated"}, "left": "requester_principal_id", "right": "approver_principal_id"},
    "PG-EMERGENCY-STOP-NO-DELAY": {"operator": "prohibit_requirement", "when": {"request_kind": "emergency_stop"}, "requirement": "approval_before_stop_request"}
  },
  "cross_guards": [
    {"id": "PG-SCOPE-MATCH", "required": true},
    {"id": "PG-ACTOR-PURPOSE", "required": true},
    {"id": "PG-PROPOSAL-AUTHORITY", "required": true},
    {"id": "PG-COMMIT-AUTHORITY", "required_at": "commit"},
    {"id": "PG-APPROVAL-NOT-AUTHORITY", "required": true},
    {"id": "PG-COMMIT-REVALIDATE", "required_at": "commit"},
    {"id": "PG-TARGET-BOUND-WORK", "conditional": true},
    {"id": "PG-COMPENSATION-TARGET", "conditional": true},
    {"id": "PG-NO-INTENT", "required": true},
    {"id": "PG-COMPENSATION-SEPARATE-INTENT", "conditional": true},
    {"id": "PG-INDETERMINATE-RESTRICT", "conditional": true}
  ],
  "default_deny": {
    "unknown_goal_state": "deny",
    "unknown_action_state": "deny",
    "unknown_actor": "deny_and_audit",
    "unknown_purpose": "deny_and_audit",
    "unknown_transition": "deny_and_audit",
    "missing_or_stale_authority": "deny",
    "missing_or_stale_policy": "deny",
    "missing_or_replayed_approval": "deny_and_audit",
    "scope_mismatch": "deny_and_audit"
  }
}
