{
  "document_type": "neural_brain_system_boundary",
  "format_version": 2,
  "contract_id": "neural-brain.system-boundary",
  "contract_version": "2.0.0",
  "status": "normative_target",
  "decision": "ADR-018",
  "system_kind": "integrated_neural_cognitive_system",
  "current_maturity": "memory_core_foundation",
  "target_capabilities": [
    "active perception and multimodal binding",
    "attention and salience",
    "neural cognitive workspace",
    "working episodic semantic and procedural memory",
    "world self and value models",
    "goal lifecycle and executive control",
    "planning and action selection",
    "closed-loop effect observation and independent verification",
    "continual learning consolidation transfer and metacognition"
  ],
  "cognitive_plane": {
    "may_propose": [
      "belief updates",
      "goal transitions",
      "plans",
      "action intents",
      "memory transitions",
      "learning and model candidates"
    ],
    "may_directly_write_protected_state": false,
    "may_directly_execute_external_effects": false
  },
  "protected_control_plane": {
    "sole_writers": {
      "goal_state": "Goal Transition Gate",
      "action_state": "Action Transition Gate",
      "memory_state": "Memory Transition Gate",
      "active_model_state": "Learning and Model Promotion Gate"
    },
    "external_effect_requirements": [
      "authenticated principal and immutable scope",
      "committed action intent",
      "authority snapshot",
      "policy decision",
      "required approval",
      "budget reservation",
      "resource claims",
      "valid runtime fence",
      "enabled kill switch",
      "sandbox policy",
      "atomic auditability"
    ],
    "independent_components": [
      "executor",
      "goal and effect verifier",
      "safety supervisor",
      "kill switch and credential revocation plane",
      "learning candidate promoter"
    ]
  },
  "scope": {
    "object_hierarchy": ["brain", "tenant", "area", "project", "session", "goal"],
    "isolation_scope_order": ["brain", "tenant", "area", "project", "session"],
    "goal_is_scope_dimension": false,
    "trusted_source": "authenticated runtime context",
    "untrusted_sources": [
      "prompts",
      "observations",
      "model output",
      "memory content",
      "tool output",
      "request payloads"
    ]
  },
  "memory_core": {
    "governing_decisions": ["ADR-015", "ADR-016", "ADR-017"],
    "role": "protected subsystem",
    "retained_invariants": [
      "immutable authenticated scope",
      "provenance and freshness",
      "Memory Transition Gate sole writer",
      "atomic mutation and audit",
      "retention and derivative deletion",
      "candidate producer and promoter separation",
      "Area-local Dreaming"
    ]
  },
  "non_claims": [
    "consciousness",
    "sentience",
    "subjective experience",
    "human-level intelligence",
    "biological or neurophysiological fidelity",
    "production autonomy"
  ],
  "default_behavior": "deny_unknown_or_unproven_state"
}
