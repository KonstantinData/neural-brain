{
  "document_type": "memory_inference_provider_contract",
  "format_version": 1,
  "contract_id": "neural-brain.memory-inference-provider",
  "contract_version": "1.0.0",
  "status": "normative",
  "decisions": [
    "ADR-014",
    "ADR-015"
  ],
  "internal_port": {
    "id": "MemoryInferencePort",
    "provider_neutral": true,
    "allowed_functions": [
      "memory content classification proposal",
      "memory candidate extraction",
      "retrieval query expansion",
      "semantic similarity support",
      "candidate assessment support",
      "memory summarization with provenance references"
    ],
    "non_functions": [
      "goal creation or lifecycle management",
      "planning",
      "tool or adapter execution",
      "external effects",
      "action-intent creation or lifecycle management",
      "authorization or approval",
      "direct memory retrieval",
      "direct protected memory mutation",
      "independent candidate promotion",
      "consumer task-success determination"
    ],
    "output_trust": "untrusted",
    "output_rule": "Every output requires strict runtime schema validation, authenticated scope binding, provenance, policy evaluation, and the applicable Memory Gate path before persistence or use."
  },
  "approved_adapters": [
    {
      "adapter_id": "ollama_local",
      "provider": "ollama",
      "deployment_boundary": "local_non_public",
      "enabled_only_when_deployment_approval_is_complete": true
    }
  ],
  "deployment_configuration": {
    "trust_source": "trusted_deployment_configuration_and_authoritative_runtime_state",
    "request_override": "denied",
    "required": [
      "exact approved local endpoint",
      "exact model identity and digest",
      "positive bounded timeout",
      "approved inference budget",
      "payload-minimized logging",
      "active egress controls"
    ],
    "forbidden": [
      "OpenAI or other cloud-provider credentials",
      "public inference endpoint",
      "provider fallback",
      "model fallback",
      "automatic cloud fallback",
      "request-selected provider, endpoint, model, timeout, budget, or logging policy"
    ]
  },
  "request_controls": {
    "scope_source": "authenticated_runtime_context_only",
    "cross_area_context": "denied",
    "data_minimization": "required",
    "secrets_and_credentials": "denied",
    "server_side_conversation_reuse": "denied",
    "cross_scope_batching_or_cache": "denied",
    "missing_budget_or_timeout": "deny_before_invocation"
  },
  "memory_boundary": {
    "adapter_initiated_retrieval": "denied",
    "adapter_direct_memory_write": "denied",
    "adapter_direct_candidate_promotion": "denied",
    "model_output_may_define_scope_actor_or_governance": false,
    "stage_1_persistent_output": "inactive_non_retrievable_candidate_only"
  },
  "readiness_gate": {
    "default": "not_ready",
    "all_required": [
      "approved adapter and local endpoint match",
      "model identity and digest match",
      "timeout and budget enforcement are active",
      "payload-minimized logging is active",
      "egress controls are active",
      "external provider and fallback configuration are absent"
    ],
    "insufficient_evidence": [
      "process alive",
      "port open",
      "HTTP success",
      "model name or tag without verified digest"
    ]
  },
  "failure_behavior": {
    "default": "fail_closed",
    "automatic_provider_switch": "denied",
    "automatic_model_switch": "denied",
    "automatic_cloud_fallback": "denied",
    "retry": "No automatic retry is granted. Any separately authorized bounded retry uses the same approved local endpoint and exact model identity under the same scope, policy, timeout, and budget."
  },
  "logging": {
    "mode": "payload_minimized",
    "allowed_by_default": [
      "trusted trace reference",
      "approved model identity reference",
      "timing and resource usage",
      "typed outcome"
    ],
    "excluded_by_default": [
      "prompt body",
      "response body",
      "raw memory content",
      "raw audit payload"
    ],
    "always_denied": [
      "secrets",
      "credentials",
      "API keys"
    ]
  },
  "future_provider_rule": "A new provider requires a separate accepted ADR, explicit adapter approval, egress and privacy assessment, updated contract, and automated safety tests. Configuration alone cannot enable it."
}
