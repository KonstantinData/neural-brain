{
  "document_type": "neural_brain_stage_capabilities",
  "format_version": 3,
  "contract_id": "neural-brain.stage-capabilities",
  "contract_version": "3.0.0",
  "status": "normative_target",
  "decision": "ADR-018",
  "semantics": {
    "domain": "integrated_neural_cognitive_system",
    "stage_order": [
      "nb_0",
      "nb_1",
      "nb_2",
      "nb_3",
      "nb_4",
      "nb_5",
      "nb_6",
      "nb_7",
      "nb_8"
    ],
    "cumulative": true,
    "unknown_operation": "denied",
    "later_stage_early_enablement": "denied",
    "failed_or_unknown_gate": "release_stop"
  },
  "stages": [
    {
      "id": "nb_0",
      "name": "Foundation Rebaseline",
      "capabilities": [
        "full-system contracts",
        "recognition and evaluation harness",
        "protected Memory Core foundation"
      ],
      "prohibited": ["productive cognition", "external effects", "active model learning"]
    },
    {
      "id": "nb_1",
      "name": "Safe Serial Neural Cognition",
      "capabilities": [
        "stateful neural workspace",
        "attention and working memory",
        "internal goal and planning proposals",
        "recorded or synthetic observations"
      ],
      "prohibited": ["live external effects", "online active-model mutation", "parallel goals"]
    },
    {
      "id": "nb_2",
      "name": "Perception, Attention, and World Model",
      "capabilities": [
        "temporal active perception",
        "multimodal binding",
        "action-conditioned world model",
        "simulation-only active sensing"
      ],
      "prohibited": ["uncontrolled external effects", "observation-prediction conflation"]
    },
    {
      "id": "nb_3",
      "name": "Differentiated Memory and Retrieval",
      "capabilities": [
        "working episodic semantic and procedural memory",
        "scope-safe retrieval",
        "freshness uncertainty contradiction and deletion"
      ],
      "prohibited": ["automatic risky promotion", "procedural memory as execution authority"]
    },
    {
      "id": "nb_4",
      "name": "Learning, Consolidation, and Plasticity",
      "capabilities": [
        "selective replay",
        "fast and slow learning paths",
        "immutable model candidates",
        "independent promotion canary and rollback"
      ],
      "prohibited": ["in-place productive self-modification", "self-change of safety or evaluation"]
    },
    {
      "id": "nb_5",
      "name": "Closed Perception-Cognition-Action Loop",
      "capabilities": [
        "bounded single-goal action",
        "controlled tool sandbox",
        "post-action observation",
        "independent effect and goal verification"
      ],
      "prohibited": ["unbounded tools", "parallel goals", "distributed execution ownership"]
    },
    {
      "id": "nb_6",
      "name": "Transfer, Causality, and Metacognition",
      "capabilities": [
        "continual adaptation",
        "causal interventions",
        "held-out transfer",
        "calibrated stop ask explore fallback and escalate"
      ],
      "prohibited": ["self-authorization", "self-selected success criteria"]
    },
    {
      "id": "nb_7",
      "name": "Multi-Goal Executive Control",
      "capabilities": [
        "hierarchical goals",
        "preemption and fair scheduling",
        "attention budget and resource arbitration"
      ],
      "prohibited": ["unauthorized goal creation", "safety goal preemption"]
    },
    {
      "id": "nb_8",
      "name": "Distributed Operation and Scale",
      "capabilities": [
        "fenced distributed ownership",
        "durable queues leases and failover",
        "disaster recovery",
        "governed cross-Area abstraction"
      ],
      "prohibited": ["split-brain authority", "implicit raw cross-Area sharing"]
    }
  ],
  "recognition": {
    "minimum_stage_for_candidate_label": "nb_6",
    "required_evaluation_gate": "g8",
    "production_autonomy_is_separate_approval": true
  }
}
